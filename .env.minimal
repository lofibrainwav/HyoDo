# HyoDo minimal configuration (English)
# Public CLI gates do not require provider keys.
# Extended adapters may use keys when you enable them.

# Optional provider key (Claude adapter only)
ANTHROPIC_API_KEY=

# Optional other providers (leave empty if unused)
OPENAI_API_KEY=
XAI_API_KEY=
GOOGLE_API_KEY=

# Review-signal thresholds (not merge authorization)
REVIEW_SIGNAL_STRONG_THRESHOLD=90
REVIEW_SIGNAL_CAUTION_THRESHOLD=70

# Feature flags for optional tooling
SAFETY_GATE_ENABLED=true
EVIDENCE_LOG_ENABLED=true
METRICS_ENABLED=true
DEBUG=false
LOG_LEVEL=INFO

# Default routing tier intent (FREE | STANDARD | PREMIUM)
DEFAULT_COST_TIER=FREE
