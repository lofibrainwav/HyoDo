# ─────────────────────────────────────────────────────────────────
# HyoDo Example Configuration
# Do not commit real secrets. Copy this file to .env and replace placeholders.
# ─────────────────────────────────────────────────────────────────

# Claude API
# Required only when using Claude Code / Anthropic-backed workflows.
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ─────────────────────────────────────────────────────────────────
# HYOGOOK V5 / Trinity Thresholds
# ─────────────────────────────────────────────────────────────────
TRINITY_AUTO_RUN_THRESHOLD=90
TRINITY_ASK_COMMANDER_THRESHOLD=70
TRINITY_BLOCK_THRESHOLD=0

# ─────────────────────────────────────────────────────────────────
# Safety & Logging
# ─────────────────────────────────────────────────────────────────
SAFETY_GATE_ENABLED=true
EVIDENCE_LOG_ENABLED=true
METRICS_ENABLED=true

# ─────────────────────────────────────────────────────────────────
# Optional Local Services
# These are used only when running the extended local stack.
# ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
POSTGRES_URL=postgresql://hyodo:hyodo@localhost:5432/hyodo
OLLAMA_BASE_URL=http://localhost:11434

# ─────────────────────────────────────────────────────────────────
# Development
# ─────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
