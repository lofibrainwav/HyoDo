# HyoDo Environment Configuration
# Copy this file to .env and fill in your values

# ─────────────────────────────────────────
# Claude API (Required)
# ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ─────────────────────────────────────────
# Ollama (Optional - for 오호대장군)
# ─────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL_GUAN_YU=qwen2.5-coder:7b
OLLAMA_MODEL_ZHANG_FEI=deepseek-r1:7b
OLLAMA_MODEL_ZHAO_YUN=qwen3:8b
OLLAMA_MODEL_MA_CHAO=codestral:latest
OLLAMA_MODEL_HUANG_ZHONG=qwen3-vl:latest

# ─────────────────────────────────────────
# Cost Optimization
# ─────────────────────────────────────────
DEFAULT_COST_TIER=FREE
# Options: FREE (Ollama), CHEAP (Haiku), EXPENSIVE (Opus)

# ─────────────────────────────────────────
# Trinity Score Thresholds
# ─────────────────────────────────────────
TRINITY_AUTO_RUN_THRESHOLD=90
TRINITY_ASK_COMMANDER_THRESHOLD=70
TRINITY_BLOCK_THRESHOLD=0

# ─────────────────────────────────────────
# Safety Gate
# ─────────────────────────────────────────
SAFETY_GATE_ENABLED=true
SAFETY_GATE_BLOCK_PRODUCTION=true

# ─────────────────────────────────────────
# Evidence Logging
# ─────────────────────────────────────────
EVIDENCE_LOG_ENABLED=true
EVIDENCE_LOG_PATH=.claude/evidence/

# ─────────────────────────────────────────
# Metrics
# ─────────────────────────────────────────
METRICS_ENABLED=true
METRICS_EMIT_INTERVAL=60

# ─────────────────────────────────────────
# Email Notifications (Optional)
# ─────────────────────────────────────────
IRS_EMAIL_ENABLED=false
IRS_EMAIL_SMTP_HOST=smtp.gmail.com
IRS_EMAIL_SMTP_PORT=587
IRS_EMAIL_SMTP_USER=your-email@gmail.com
IRS_EMAIL_SMTP_PASSWORD=your-app-password
IRS_EMAIL_FROM=alerts@your-domain.com
IRS_EMAIL_TO=admin@your-domain.com

# ─────────────────────────────────────────
# Development
# ─────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
