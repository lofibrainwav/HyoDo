    "event_id",
    "kind"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": [
        "tool_call",
        "prompt"
      ]
    }
  },
  "additionalProperties": false
}
